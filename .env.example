# ── Database ──────────────────────────────────────────────
# DATABASE_URL = pooled connection (port 6543) — used by your live app for normal queries
# DIRECT_URL   = direct connection (port 5432) — used only when running migrations
# Both come from Supabase → Connect button → ORMs tab
DATABASE_URL="postgresql://postgres.xxxxxxxxxxxx:[Tundeez123%3F]@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.xxxxxxxxxxxx:[Tundeez123%3F]@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# ── Auth ──────────────────────────────────────────────────
# Generate a strong random string: run `openssl rand -base64 32` in your terminal
JWT_SECRET="replace-this-with-a-long-random-string"

# ── Cloudinary (for product image uploads) ───────────────
# Sign up free at cloudinary.com, then go to Dashboard for these values
# Create an "unsigned" upload preset at Settings → Upload → Upload presets
CLOUDINARY_CLOUD_NAME="your-cloud-name"
CLOUDINARY_UPLOAD_PRESET="your-upload-preset"
# From your Paystack dashboard → Settings → API Keys & Webhooks
# Use the TEST keys while developing, LIVE keys only when going live
PAYSTACK_SECRET_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxx"
PAYSTACK_PUBLIC_KEY="pk_test_xxxxxxxxxxxxxxxxxxxxx"

# ── App ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL="http://localhost:5173"
ADMIN_URL="http://localhost:5174"
